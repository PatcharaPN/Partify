// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "commonjs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") 
}

enum Role {
  CANDIDATE
  EMPLOYER
  ADMIN
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  INTERVIEW
}

model User {
  id          String   @id @default(uuid())
  email       String?   @unique
  password    String?
  role        Role     @default(CANDIDATE)
  createdAt   DateTime @default(now())
  accounts    Account[]

  profile     Profile?
  bookmarks   Bookmark[]  
  jobs        Job[]        @relation("EmployerJobs")
  applications Application[]

  @@map("users")
}

model Account {
  id                String @id @default(uuid())
  provider          String
  providerAccountId String
  userId            String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Profile {
  id           String   @id @default(uuid())
  userId       String   @unique

  name         String
  phone        String?
  summary      String?   
  workingHours      String?

  skills       String[]   
  shifts       String[]  
  availability String[]   
  experience   String[]

  resumeUrl    String?
  avatarUrl    String?
  birthDate    DateTime?
  reliabilityScore Int? @default(100)
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Job {
  id                String    @id @default(uuid())
  title             String
  description       String
  responsibilities  String?
  qualifications    String?

  salaryMin         Int?
  salaryMax         Int?
  salaryNegotiable  Boolean   @default(false)
  currency          String?   @default("THB")
  status            String?
  jobType           String?
  workStyle         String?
  experienceLevel   String?
  experienceYears   Int?
  educationLevel    String?
  positions         Int?      @default(1)

  workingHours      String?
  workingDays       String?
  startDate         DateTime?
  closingDate       DateTime?

  overviewPictureURL String[]

  benefits          String[]
  bookmarks         Bookmark[]  
  location          String?
  urgency           String?
  createdAt         DateTime  @default(now())
  
  companyId         String
  company           User      @relation("EmployerJobs", fields: [companyId], references: [id])
  companyImageURL   String?
  companyName       String?

  applications      Application[]
  skills            JobSkill[]    

  @@map("jobs")
}

model Bookmark {
  id      String  @id @default(uuid())
  userId  String
  jobId   String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  job     Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("bookmarks")
}

model JobSkill {
  id      String  @id @default(uuid())
  jobId   String
  job     Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name    String  

  @@map("job_skills")
}

model Application {
  id        String             @id @default(uuid())
  jobId     String
  userId    String
  status    ApplicationStatus  @default(PENDING)
  createdAt DateTime           @default(now())
  job       Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@map("applications")
}